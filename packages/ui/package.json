{
  "name": "@repo/ui",
  "version": "0.0.0",
  "description": "디자인 시스템 / 공통 React 컴포넌트 (SSOT 도메인 무지)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": {
      "development": "./src/styles/globals.css",
      "default": "./dist/style.css"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.5",
    "@xyflow/react": "^12.9.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.12",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.1.1",
    "tailwindcss": "^4.1.12",
    "typescript": "5.9.2",
    "vite": "^7.2.2",
    "vite-plugin-dts": "^4.5.4"
  }
}
